# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# PlatformIO build artifacts
.pio/

# VSCode settings (keep config files but ignore build output)
.vscode/build/
.vscode/build-host/
.vscode/build-coverage/
# Auto-generated by PlatformIO — machine-specific paths, must not be committed
.vscode/c_cpp_properties.json
.vscode/launch.json

# Host test build artifacts
test/build/

# IDE/Editor files
.idea/
*.swp
*.swo

# Generated documentation (built by CI, not committed)
docs/api/
docs/coverage/

# Local Claude settings (user-specific permissions)
.claude/settings.local.json

# Dev container local secrets (API keys — never commit)
.devcontainer/.env

# Python
__pycache__/
*.pyc
*.pyo

# Flutter / Dart app build artifacts
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/android/.gradle/
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/flutter_export_environment.sh
