{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "config.schema.json",
  "title": "AwesomeStudioPedal Hardware Config",
  "type": "object",
  "required": ["hardware", "numProfiles", "numSelectLeds", "numButtons", "ledBluetooth", "ledPower", "ledSelect", "buttonSelect", "buttonPins"],
  "additionalProperties": false,
  "properties": {
    "_doc": { "type": "string" },
    "hardware": {
      "type": "string",
      "enum": ["esp32", "nrf52840"]
    },
    "numProfiles": {
      "type": "integer",
      "minimum": 1
    },
    "numSelectLeds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "numButtons": {
      "type": "integer",
      "minimum": 1,
      "maximum": 26
    },
    "ledBluetooth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 39
    },
    "ledPower": {
      "type": "integer",
      "minimum": 0,
      "maximum": 39
    },
    "ledSelect": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 39 }
    },
    "buttonSelect": {
      "type": "integer",
      "minimum": 0,
      "maximum": 39
    },
    "buttonPins": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 39 }
    },
    "pairing_pin": {
      "description": "BLE pairing passkey (TASK-237). null or absent = no auth; integer 0–999999 = passkey auth.",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 999999
    }
  }
}
