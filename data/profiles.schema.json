{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "profiles.schema.json",
  "title": "AwesomeStudioPedal Profiles",
  "type": "object",
  "required": ["profiles"],
  "additionalProperties": false,
  "properties": {
    "_doc": { "type": "string" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "buttons"],
        "additionalProperties": false,
        "properties": {
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "buttons": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/actionObject" }
          }
        }
      }
    }
  },
  "$defs": {
    "actionObject": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SendStringAction",
            "SendCharAction",
            "SendKeyAction",
            "SendMediaKeyAction",
            "SerialOutputAction",
            "DelayedAction",
            "PinHighAction",
            "PinLowAction",
            "PinToggleAction",
            "PinHighWhilePressedAction",
            "PinLowWhilePressedAction",
            "MacroAction"
          ]
        },
        "name":       { "type": "string" },
        "value":      { "type": "string" },
        "pin":        { "type": "integer" },
        "delayMs":    { "type": "integer", "minimum": 0 },
        "action":     { "$ref": "#/$defs/actionObject" },
        "steps": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "$ref": "#/$defs/actionObject" }
          }
        },
        "longPress":   { "$ref": "#/$defs/actionObject" },
        "doublePress": { "$ref": "#/$defs/actionObject" }
      }
    }
  }
}
