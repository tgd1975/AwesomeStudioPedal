{
  "permissions": {
    "allow": [
      "Bash(adb devices)",
      "Bash(adb devices *)",
      "Bash(adb -s * devices)",
      "Bash(adb -s * shell getprop *)",
      "Bash(adb -s * shell settings get *)",
      "Bash(adb -s * shell svc bluetooth *)",
      "Bash(adb -s * shell am force-stop *)",
      "Bash(adb -s * shell am start *)",
      "Bash(adb -s * shell am broadcast *)",
      "Bash(adb -s * shell pm grant *)",
      "Bash(adb -s * shell pm revoke *)",
      "Bash(adb -s * shell pm list *)",
      "Bash(adb -s * shell pm path *)",
      "Bash(adb -s * shell content query *)",
      "Bash(adb -s * shell content call *)",
      "Bash(adb -s * shell wm size)",
      "Bash(adb -s * shell wm density)",
      "Bash(adb -s * shell monkey -p com.example.awesome_studio_pedal *)",
      "Bash(adb -s * shell uiautomator dump *)",
      "Bash(adb -s * shell input *)",
      "Bash(adb -s * shell screencap *)",
      "Bash(adb -s * shell dumpsys *)",
      "Bash(adb -s * shell cmd clipboard *)",
      "Bash(adb -s * exec-out screencap*)",
      "Bash(adb -s * pull /sdcard/* /tmp/*)",
      "Bash(adb -s * push * /sdcard/Download/*)",
      "Bash(adb -s * push * /sdcard/*)",
      "Bash(adb -s * install -r -t *)",
      "Bash(adb -s * install -r *)",
      "Bash(adb -s * logcat -c)",
      "Bash(adb -s * logcat -d *)",
      "Bash(adb -s * logcat -t *)",
      "Bash(adb -s * forward tcp:* tcp:*)",
      "Bash(adb -s * shell ls /sdcard/*)",
      "Bash(grep * /tmp/ui.xml)",
      "Bash(grep * /tmp/ui.xml*)",
      "Bash(stat /tmp/*)",
      "Bash(python3 test/tools/ui_find.py *)",
      "Bash(python3 scripts/screenshot.py *)",
      "Bash(python3 scripts/pedal_config.py validate *)",
      "Bash(python3 -m pytest scripts/tests/*)",
      "Bash(python3 -m pytest scripts/tests/* *)",
      "Bash(.venv/bin/python -m pytest scripts/tests/*)",
      "Bash(.venv/bin/python -m pytest scripts/tests/* *)",
      "Bash(python3 -m unittest discover *)",
      "Bash(.venv/bin/python -m unittest discover *)",
      "Bash(python3 -m unittest scripts.tests.*)",
      "Bash(.venv/bin/python -m unittest scripts.tests.*)",
      "Bash(flutter --version)",
      "Bash(flutter pub get)",
      "Bash(flutter pub get *)",
      "Bash(flutter run)",
      "Bash(flutter run *)",
      "Bash(flutter build *)",
      "Bash(flutter install)",
      "Bash(flutter install *)",
      "Bash(python3 scripts/security_review_changes.py *)",
      "Bash(bash scripts/install_git_hooks.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'nohup python3 scripts/claude_recap.py >/dev/null 2>&1 & disown ; exit 0'",
            "statusMessage": "Triggering background claude-recap..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cmd=$(jq -r \".tool_input.command // \\\"\\\"\" 2>/dev/null); echo \"$cmd\" | grep -qE \"git (commit|merge|push)\" || exit 0; branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$branch\" = \"main\" ] && echo \"WARNING: You are about to run \\\"$cmd\\\" on the main branch. This is usually wrong — consider working on a feature branch instead. Proceeding anyway? If not, stop and create a branch first.\" >&2; exit 0'",
            "statusMessage": "Checking branch before git operation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; echo \"$f\" | grep -q '\\.claude/skills/' && python scripts/sync_skills_config.py; } 2>/dev/null || true",
            "statusMessage": "Syncing skills config..."
          }
        ]
      }
    ]
  }
}
