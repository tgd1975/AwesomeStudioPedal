#!/usr/bin/env bash
# Comprehensive pre-commit hook for code quality checks
# Usage: ./pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
# Use separate build dirs for host and dev container to avoid CMake cache
# conflicts caused by differing absolute paths (/home/... vs /workspaces/...).
if [ -f "/.dockerenv" ]; then
    BUILD_DIR="${REPO_ROOT}/.vscode/build"
else
    BUILD_DIR="${REPO_ROOT}/.vscode/build-host"
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Commit-provenance check (EPIC-022)
# ---------------------------------------------------------------------------
# Every commit on this repo must flow through the /commit skill, which uses
# scripts/commit-pathspec.sh as its executable. That script writes a one-shot
# token at .git/asp-commit-token; this hook validates the token and deletes
# it. Commits without a valid token are rejected — see
# docs/developers/COMMIT_POLICY.md for the full design.
#
# Bypass: ASP_COMMIT_BYPASS=<non-empty reason> in the env. Logged to
# .git/asp-commit-bypass.log for periodic review.
# ---------------------------------------------------------------------------

GIT_DIR="$(git rev-parse --git-dir)"
TOKEN_FILE="${GIT_DIR}/asp-commit-token"
BYPASS_LOG="${GIT_DIR}/asp-commit-bypass.log"

if [ -n "${ASP_COMMIT_BYPASS:-}" ]; then
    # Audit log line — SHA is unknown until post-commit, so we log "pending".
    NOW_ISO="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    USER_NAME="${USER:-$(id -un)}"
    printf '%s\t%s\t%s\t%s\t%s\n' \
        "${NOW_ISO}" "${ASP_COMMIT_BYPASS}" "pending" \
        "${BRANCH}" "${USER_NAME}" >> "${BYPASS_LOG}"
    echo -e "${YELLOW}/commit bypass: ${ASP_COMMIT_BYPASS} (logged to ${BYPASS_LOG})${NC}"
    # Drop any stale token left by a prior /commit attempt — bypass should
    # never piggy-back on a token from a different invocation.
    rm -f "${TOKEN_FILE}"
else
    if [ ! -f "${TOKEN_FILE}" ]; then
        echo -e "${RED}ERROR: commit did not flow through /commit.${NC}" >&2
        echo "" >&2
        echo "  Use the /commit skill (scripts/commit-pathspec.sh) for every commit." >&2
        echo "  Bypass for legitimate cases (rebase, recovery): set" >&2
        echo "  ASP_COMMIT_BYPASS=\"<reason>\" in the env. See" >&2
        echo "  docs/developers/COMMIT_POLICY.md." >&2
        exit 1
    fi

    # Validate token format and freshness.
    TOKEN_LINE="$(head -n1 "${TOKEN_FILE}")"
    # Expected: <pid> <nonce> <unix-ts>
    if ! echo "${TOKEN_LINE}" | grep -qE '^[0-9]+ [0-9a-f]+ [0-9]+$'; then
        rm -f "${TOKEN_FILE}"
        echo -e "${RED}ERROR: malformed commit-provenance token. Rejecting.${NC}" >&2
        exit 1
    fi
    TOKEN_PID="$(echo "${TOKEN_LINE}" | awk '{print $1}')"
    TOKEN_TS="$(echo "${TOKEN_LINE}" | awk '{print $3}')"
    NOW_TS="$(date +%s)"
    AGE=$((NOW_TS - TOKEN_TS))
    if [ "${AGE}" -lt 0 ] || [ "${AGE}" -gt 60 ]; then
        rm -f "${TOKEN_FILE}"
        echo -e "${RED}ERROR: commit-provenance token is stale (age ${AGE}s, max 60s). Rejecting.${NC}" >&2
        echo "  Re-run /commit." >&2
        exit 1
    fi
    # PID-ancestry check: the token's PID must be a *near* ancestor of
    # this hook process. The expected chain is:
    #   commit-pathspec.sh (writes token, PID=$$)
    #   └── git commit (child)
    #       └── pre-commit hook (this script, $$)
    # so the token PID == hook's grandparent. Walk at most 3 levels up to
    # tolerate shell wrappers, but no further — walking to init/1 would
    # accept any PID and defeat the check.
    PID_OK=0
    if [ -d /proc ]; then
        CHECK_PID="$$"
        for _ in 1 2 3; do
            if [ ! -r "/proc/${CHECK_PID}/status" ]; then
                break
            fi
            PARENT="$(awk '/^PPid:/ {print $2}' "/proc/${CHECK_PID}/status" 2>/dev/null || echo 0)"
            if [ -z "${PARENT}" ] || [ "${PARENT}" = "0" ] || [ "${PARENT}" = "${CHECK_PID}" ]; then
                break
            fi
            CHECK_PID="${PARENT}"
            if [ "${CHECK_PID}" = "${TOKEN_PID}" ]; then
                PID_OK=1
                break
            fi
        done
    else
        # Best-effort: just compare to direct parent.
        if [ "${PPID}" = "${TOKEN_PID}" ]; then
            PID_OK=1
        fi
    fi
    if [ "${PID_OK}" -ne 1 ]; then
        rm -f "${TOKEN_FILE}"
        echo -e "${RED}ERROR: commit-provenance token PID ${TOKEN_PID} is not an ancestor of this hook. Rejecting.${NC}" >&2
        echo "  This usually means a stale token from another shell. Re-run /commit." >&2
        exit 1
    fi

    # All checks passed — consume the token.
    rm -f "${TOKEN_FILE}"
fi

echo -e "${GREEN}/commit provenance OK.${NC}"

# Gate the C++ checks (clang-format here, clang-tidy + host-test below) on
# whether this commit's staged paths actually touch C++ inputs. Use --cached
# so unrelated working-tree edits from parallel sessions don't trigger heavy
# checks — pathspec-form commits routinely leave foreign mods around.
STAGED_CPP_PATHS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(lib|inc|src|test)/' || true)

echo -e "${YELLOW}Checking C++ code formatting...${NC}"

if [ -z "$STAGED_CPP_PATHS" ]; then
    echo -e "${GREEN}No C++ paths staged — skipping clang-format.${NC}"
else
    CLANGFORMAT=$(command -v clang-format 2>/dev/null || true)
    if [ -n "$CLANGFORMAT" ]; then
        # Check if clang-format is available
        FILES_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|hpp)$' || true)
        if [ -n "$FILES_CHANGED" ]; then
            echo "Checking formatting for changed files:"
            echo "$FILES_CHANGED"

            # Check formatting
            FORMAT_ISSUES=0
            for file in $FILES_CHANGED; do
                if ! "$CLANGFORMAT" --dry-run --Werror "$file"; then
                    FORMAT_ISSUES=1
                fi
            done

            if [ $FORMAT_ISSUES -ne 0 ]; then
                echo -e "${RED}C++ code formatting issues found. Run 'clang-format -i' to fix.${NC}"
                exit 1
            fi
        fi
        echo -e "${GREEN}C++ formatting OK.${NC}"
    else
        echo -e "${YELLOW}clang-format not found, skipping C++ formatting check.${NC}"
    fi
fi

echo -e "${YELLOW}Checking Markdown formatting...${NC}"

MARKDOWNLINT=$(command -v markdownlint-cli2 2>/dev/null)
if [ -z "$MARKDOWNLINT" ]; then
    NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        \. "$NVM_DIR/nvm.sh" --no-use 2>/dev/null || true
        MARKDOWNLINT=$(command -v markdownlint-cli2 2>/dev/null)
    fi
fi

if [ -n "$MARKDOWNLINT" ]; then
    "$MARKDOWNLINT" "*.md" 2>&1
    if [ $? -ne 0 ]; then
        echo -e "${RED}Markdown lint failed. Commit aborted.${NC}"
        exit 1
    fi
    echo -e "${GREEN}Markdown OK.${NC}"
else
    echo -e "${YELLOW}markdownlint-cli2 not found, skipping markdown check.${NC}"
fi

echo -e "${YELLOW}Validating JSON schemas...${NC}"

PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
if [ -n "$PYTHON" ]; then
    "$PYTHON" - <<'PYEOF'
import sys, json, pathlib, importlib.util

repo = pathlib.Path(__file__).resolve().parent.parent

def load(p):
    with open(p) as f:
        return json.load(f)

pairs = [
    ("data/profiles.json", "data/profiles.schema.json"),
]
config_json = repo / "data/config.json"
config_schema = repo / "data/config.schema.json"
if config_json.exists() and config_schema.exists():
    pairs.append(("data/config.json", "data/config.schema.json"))
    # Cross-field check: numProfiles <= 2^numSelectLeds - 1
    cfg = load(config_json)
    max_profiles = (1 << cfg["numSelectLeds"]) - 1
    if cfg["numProfiles"] > max_profiles:
        print(f"ERROR: config.json numProfiles ({cfg['numProfiles']}) exceeds "
              f"2^numSelectLeds-1 ({max_profiles}) for numSelectLeds={cfg['numSelectLeds']}")
        sys.exit(1)
    if cfg["numButtons"] != len(cfg["buttonPins"]):
        print(f"ERROR: config.json numButtons ({cfg['numButtons']}) != len(buttonPins) ({len(cfg['buttonPins'])})")
        sys.exit(1)
    if cfg["numSelectLeds"] != len(cfg["ledSelect"]):
        print(f"ERROR: config.json numSelectLeds ({cfg['numSelectLeds']}) != len(ledSelect) ({len(cfg['ledSelect'])})")
        sys.exit(1)

try:
    import jsonschema
except ImportError:
    print("jsonschema not installed — skipping JSON schema validation (pip install jsonschema)")
    sys.exit(0)

errors = 0
for data_rel, schema_rel in pairs:
    data_path = repo / data_rel
    schema_path = repo / schema_rel
    if not data_path.exists():
        continue
    try:
        validator = jsonschema.Draft7Validator(load(schema_path))
        errs = list(validator.iter_errors(load(data_path)))
        if errs:
            for e in errs:
                print(f"  {data_rel}: {e.message} (at {list(e.path)})")
            errors += 1
        else:
            print(f"  OK: {data_rel}")
    except Exception as exc:
        print(f"  ERROR validating {data_rel}: {exc}")
        errors += 1

sys.exit(1 if errors else 0)
PYEOF
    SCHEMA_STATUS=$?
    if [ $SCHEMA_STATUS -ne 0 ]; then
        echo -e "${RED}JSON schema validation failed. Commit aborted.${NC}"
        exit 1
    fi
    echo -e "${GREEN}JSON schema validation OK.${NC}"
else
    echo -e "${YELLOW}python3 not found, skipping JSON schema validation.${NC}"
fi

echo -e "${YELLOW}Checking task-system source-of-truth divergence...${NC}"

PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
if [ -n "$PYTHON" ] && [ -f "${REPO_ROOT}/scripts/sync_task_system.py" ]; then
    "$PYTHON" "${REPO_ROOT}/scripts/sync_task_system.py" --check
    if [ $? -ne 0 ]; then
        echo -e "${RED}Task-system files diverged between awesome-task-system/ and live copies.${NC}"
        echo -e "${RED}Edit the package copy, then run: python scripts/sync_task_system.py --apply${NC}"
        exit 1
    fi
    echo -e "${GREEN}Task-system in sync.${NC}"
else
    echo -e "${YELLOW}sync_task_system.py not found, skipping divergence check.${NC}"
fi

echo -e "${YELLOW}Validating Mermaid diagrams in staged Markdown...${NC}"

# Mermaid validation runs the same script CI does. Only fires when staged
# files include any .md (catches both hand-edited diagrams and the
# auto-generated KANBAN.md / EPICS.md / OVERVIEW.md regenerated by housekeep
# above). Required tools: mmdc + python3. Missing either is a loud failure
# per CLAUDE.md "Missing executables" — silent skip is what let TASK-321 land.
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
    MMDC=$(command -v mmdc 2>/dev/null || true)
    if [ -z "$MMDC" ]; then
        NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
        if [ -s "$NVM_DIR/nvm.sh" ]; then
            \. "$NVM_DIR/nvm.sh" --no-use 2>/dev/null || true
            MMDC=$(command -v mmdc 2>/dev/null || true)
        fi
    fi
    if [ -z "$MMDC" ]; then
        echo -e "${RED}mmdc not found — cannot validate Mermaid diagrams that CI checks.${NC}"
        echo -e "${RED}Install: npm install -g @mermaid-js/mermaid-cli${NC}"
        exit 1
    fi
    PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
    if [ -z "$PYTHON" ]; then
        echo -e "${RED}python3 not found — cannot run scripts/validate_mermaid.py.${NC}"
        exit 1
    fi
    "$PYTHON" "${REPO_ROOT}/scripts/validate_mermaid.py" >/dev/null
    if [ $? -ne 0 ]; then
        echo -e "${RED}Mermaid validation failed — re-run scripts/validate_mermaid.py for details. Commit aborted.${NC}"
        exit 1
    fi
    echo -e "${GREEN}Mermaid OK.${NC}"
else
    echo -e "${GREEN}No staged .md files — skipping Mermaid validation.${NC}"
fi

echo -e "${YELLOW}Running clang-tidy on staged C++ sources...${NC}"

# clang-tidy mirrors the Static Analysis CI job. Outer gate: any C++ path
# staged at all; inner gate: lib/PedalLogic/src — the same path CI scans.
# Missing the tool is a loud failure per CLAUDE.md "Missing executables".
if [ -z "$STAGED_CPP_PATHS" ]; then
    echo -e "${GREEN}No C++ paths staged — skipping clang-tidy.${NC}"
else
    STAGED_CXX=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^lib/PedalLogic/src/.*\.cpp$' || true)
    if [ -n "$STAGED_CXX" ]; then
        CLANG_TIDY=$(command -v clang-tidy 2>/dev/null || command -v clang-tidy-18 2>/dev/null || true)
        if [ -z "$CLANG_TIDY" ]; then
            echo -e "${RED}clang-tidy not found — cannot run the static analysis CI runs.${NC}"
            echo -e "${RED}Install: sudo apt install clang-tidy   (or clang-tidy-18)${NC}"
            exit 1
        fi
        # CI builds with -DCMAKE_EXPORT_COMPILE_COMMANDS=ON in .vscode/build.
        # If the host build dir lacks compile_commands.json, configure once.
        TIDY_BUILD_DIR="${REPO_ROOT}/.vscode/build"
        if [ ! -f "${TIDY_BUILD_DIR}/compile_commands.json" ]; then
            echo "Configuring CMake to emit compile_commands.json (first run)..."
            cmake -B "${TIDY_BUILD_DIR}" -S "${REPO_ROOT}" \
                  -G Ninja \
                  -DCMAKE_BUILD_TYPE=Debug \
                  -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
                  -Wno-dev \
                  --log-level=WARNING
        fi
        # Run against ALL lib/PedalLogic/src/*.cpp — the same set CI scans —
        # because clang-tidy follows includes and a header change in a non-staged
        # file can break compilation of staged sources. Capture the output so we
        # can show it on failure but stay quiet on success.
        TIDY_LOG=$(mktemp)
        set +e
        find "${REPO_ROOT}/lib/PedalLogic/src" -name "*.cpp" | \
            xargs "$CLANG_TIDY" -p "${TIDY_BUILD_DIR}" --quiet >"$TIDY_LOG" 2>&1
        TIDY_STATUS=$?
        set -e
        if [ $TIDY_STATUS -ne 0 ]; then
            grep -E "error:" "$TIDY_LOG" | head -50
            rm -f "$TIDY_LOG"
            echo -e "${RED}clang-tidy reported errors. Commit aborted.${NC}"
            echo -e "${RED}Re-run: find lib/PedalLogic/src -name '*.cpp' | xargs $CLANG_TIDY -p ${TIDY_BUILD_DIR}${NC}"
            exit 1
        fi
        rm -f "$TIDY_LOG"
        echo -e "${GREEN}clang-tidy OK.${NC}"
    else
        echo -e "${GREEN}No staged C++ sources in lib/PedalLogic/src — skipping clang-tidy.${NC}"
    fi
fi

echo -e "${YELLOW}Running unit tests before commit...${NC}"

if [ -z "$STAGED_CPP_PATHS" ]; then
    echo -e "${GREEN}No C++ paths staged — skipping host-test build/run.${NC}"
else
    if [ ! -f "${BUILD_DIR}/CMakeCache.txt" ]; then
        echo "Configuring CMake (first run)..."
        cmake -B "${BUILD_DIR}" -S "${REPO_ROOT}" \
              -DCMAKE_BUILD_TYPE=Release \
              -Wno-dev \
              --log-level=WARNING
    fi

    cmake --build "${BUILD_DIR}" --target pedal_tests -j"$(nproc)"
    BUILD_STATUS=$?

    if [ $BUILD_STATUS -ne 0 ]; then
        echo -e "${RED}Build failed. Commit aborted.${NC}"
        exit 1
    fi

    "${BUILD_DIR}/test/pedal_tests" --gtest_color=yes --gtest_brief=1
    TEST_STATUS=$?

    if [ $TEST_STATUS -ne 0 ]; then
        echo -e "${RED}Tests failed. Commit aborted.${NC}"
        exit 1
    fi

    echo -e "${GREEN}All tests passed.${NC}"
fi

FLUTTER=$(command -v flutter 2>/dev/null || true)
if [ -n "$FLUTTER" ]; then
    DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^app/' || true)
    if [ -n "$DART_FILES" ]; then
        echo -e "${YELLOW}Checking Dart formatting...${NC}"
        cd "${REPO_ROOT}/app" && dart format --output=none --set-exit-if-changed .
        if [ $? -ne 0 ]; then
            echo -e "${RED}Dart formatting check failed. Run 'make flutter-format' to fix. Commit aborted.${NC}"
            cd "${REPO_ROOT}"
            exit 1
        fi
        echo -e "${GREEN}Dart formatting OK.${NC}"

        echo -e "${YELLOW}Running flutter analyze...${NC}"
        "$FLUTTER" analyze
        if [ $? -ne 0 ]; then
            echo -e "${RED}flutter analyze failed. Commit aborted.${NC}"
            cd "${REPO_ROOT}"
            exit 1
        fi
        echo -e "${GREEN}flutter analyze OK.${NC}"

        echo -e "${YELLOW}Running Flutter tests...${NC}"
        "$FLUTTER" test
        if [ $? -ne 0 ]; then
            echo -e "${RED}Flutter tests failed. Commit aborted.${NC}"
            cd "${REPO_ROOT}"
            exit 1
        fi
        echo -e "${GREEN}Flutter tests passed.${NC}"
        cd "${REPO_ROOT}"
    fi
else
    echo -e "${YELLOW}flutter not found on PATH — skipping Flutter checks (run from host machine or CI will catch failures).${NC}"
fi

echo -e "${YELLOW}Checking devcontainer.json is well-formed...${NC}"
DEVCONTAINER="${REPO_ROOT}/.devcontainer/devcontainer.json"
if [ -f "$DEVCONTAINER" ]; then
    PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
    if [ -n "$PYTHON" ]; then
        "$PYTHON" -c "
import json, sys, re
try:
    text = open('$DEVCONTAINER').read()
    # Strip // comments not preceded by : / \" (avoids stripping URLs inside strings)
    text = re.sub(r'(?<![:\"/])//[^\n]*', '', text)
    json.loads(text)
    print('  OK: devcontainer.json is valid JSON')
except json.JSONDecodeError as e:
    print(f'  ERROR: devcontainer.json is malformed: {e}')
    sys.exit(1)
"
        if [ $? -ne 0 ]; then
            echo -e "${RED}devcontainer.json validation failed. Commit aborted.${NC}"
            exit 1
        fi
    fi
fi
echo -e "${GREEN}devcontainer.json OK.${NC}"

echo -e "${YELLOW}Checking for secrets and sensitive files...${NC}"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Fail if .devcontainer/.env is staged
if echo "$STAGED_FILES" | grep -qE '^\.devcontainer/\.env$'; then
    echo -e "${RED}ERROR: .devcontainer/.env is staged for commit. This file contains secrets and must not be committed.${NC}"
    echo "       Remove it: git restore --staged .devcontainer/.env"
    exit 1
fi

# Scan staged file contents for common secret patterns
SECRET_PATTERNS='(AKIA[0-9A-Z]{16}|ghp_[0-9a-zA-Z]{36}|sk-[a-zA-Z0-9]{32,}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----|password\s*=\s*["\x27][^"\x27]{4,}|api[_-]?key\s*=\s*["\x27][^"\x27]{8,})'
if [ -n "$STAGED_FILES" ]; then
    MATCHES=$(git diff --cached --unified=0 | grep '^+' | grep -vE '^\+\+\+' | grep -iE "$SECRET_PATTERNS" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}ERROR: Possible secrets detected in staged changes:${NC}"
        echo "$MATCHES"
        echo "       If this is a false positive, remove the matching line or contact the team."
        exit 1
    fi
fi
echo -e "${GREEN}No secrets detected.${NC}"

echo -e "${YELLOW}Updating idea overview...${NC}"
python3 "${REPO_ROOT}/scripts/update_idea_overview.py"
git add "${REPO_ROOT}/docs/developers/ideas/OVERVIEW.md"

echo -e "${YELLOW}Updating task-system overviews...${NC}"
PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
if [ -n "$PYTHON" ] && [ -f "${REPO_ROOT}/scripts/housekeep.py" ]; then
    "$PYTHON" "${REPO_ROOT}/scripts/housekeep.py" --apply
    # Stage only the regenerated index files. Do NOT stage moved task files —
    # other parallel sessions may have unstaged status edits whose moves we
    # must not sweep into this commit (per CLAUDE.md "commit only your own
    # work" rule).
    git add "${REPO_ROOT}/docs/developers/tasks/OVERVIEW.md" \
            "${REPO_ROOT}/docs/developers/tasks/EPICS.md" \
            "${REPO_ROOT}/docs/developers/tasks/KANBAN.md"
fi

exit 0
